// contracts.prisma — contracts, milestones, invoices, budgets, cost tracking

enum ContractStatus {
  DRAFT
  UNDER_REVIEW
  AWARDED          // Customer has awarded the contract; signing/handover follow
  SIGNED
  ACTIVE
  CLOSED
  DISPUTED
  TERMINATED
}

// Sub-workflow tracking the award→handover bridge into project execution.
// Independent of ContractStatus so commercial and operational phases compose cleanly.
enum HandoverStatus {
  NOT_STARTED
  READY
  IN_PROGRESS
  COMPLETED
}

enum InvoiceStatus {
  NOT_RAISED
  RAISED
  SUBMITTED
  PARTIALLY_PAID
  PAID
  DISPUTED
}

model Contract {
  id              String         @id @default(cuid())
  contractNo      String         @unique
  opportunityId   String?
  accountId       String
  // Optional cross-references for richer traceability (set by sales/PM at award time).
  siteId                       String?
  proposalVersionId            String?
  projectManagerCandidateId    String?
  title           String
  status          ContractStatus @default(DRAFT)
  scopeSummary    String?
  paymentTerms    String?
  retentionPercent Decimal?      @db.Decimal(5, 2)
  contractValue   Decimal        @db.Decimal(15, 2)
  currency        String         @default("MYR")
  awardedDate     DateTime?
  signedDate      DateTime?
  commencementDate DateTime?
  targetCod        DateTime?     // Target Commercial Operation Date
  completionDate  DateTime?
  defectsLiabilityMonths Int?
  notes           String?
  fileUrl         String?
  // Handover workflow state
  handoverStatus       HandoverStatus  @default(NOT_STARTED)
  handoverChecklist    Json?           // Free-form list: [{ key, label, done, completedAt?, completedBy? }]
  handoverCompletedAt  DateTime?
  handoverCompletedById String?
  // Linked project — set when handover completes and the project is created/found
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  account                    Account           @relation(fields: [accountId], references: [id])
  opportunity                Opportunity?      @relation(fields: [opportunityId], references: [id])
  site                       Site?             @relation(fields: [siteId], references: [id])
  proposalVersion            ProposalVersion?  @relation(fields: [proposalVersionId], references: [id])
  projectManagerCandidate    User?             @relation("ContractPMCandidate", fields: [projectManagerCandidateId], references: [id])
  handoverCompletedBy        User?             @relation("ContractHandoverCompleter", fields: [handoverCompletedById], references: [id])
  project         Project?
  milestones      ContractMilestone[]
  invoices        Invoice[]
  budgets         Budget[]
  documents       Document[]

  @@map("contracts")
}

model ContractMilestone {
  id              String        @id @default(cuid())
  contractId      String
  milestoneNo     Int
  title           String
  description     String?
  percentValue    Decimal?      @db.Decimal(5, 2)
  amount          Decimal?      @db.Decimal(15, 2)
  triggerCondition String?
  targetDate      DateTime?
  achievedDate    DateTime?
  invoiceId       String?
  isAchieved      Boolean       @default(false)

  contract        Contract      @relation(fields: [contractId], references: [id])

  @@map("contract_milestones")
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNo       String        @unique
  contractId      String
  milestoneId     String?
  amount          Decimal       @db.Decimal(15, 2)
  taxAmount       Decimal?      @db.Decimal(15, 2)
  totalAmount     Decimal       @db.Decimal(15, 2)
  currency        String        @default("MYR")
  status          InvoiceStatus @default(NOT_RAISED)
  invoiceDate     DateTime?
  dueDate         DateTime?
  paidDate        DateTime?
  paidAmount      Decimal?      @db.Decimal(15, 2)
  notes           String?
  createdAt       DateTime      @default(now())

  contract        Contract      @relation(fields: [contractId], references: [id])

  @@map("invoices")
}

model Budget {
  id              String   @id @default(cuid())
  contractId      String?
  projectId       String?
  category        String   // e.g. "Equipment", "Civil", "Labour", "Commissioning", "Others"
  description     String?
  budgetedAmount  Decimal  @db.Decimal(15, 2)
  committedAmount Decimal? @db.Decimal(15, 2)
  actualAmount    Decimal? @db.Decimal(15, 2)
  currency        String   @default("MYR")
  version         Int      @default(1)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contract        Contract? @relation(fields: [contractId], references: [id])

  @@map("budgets")
}
